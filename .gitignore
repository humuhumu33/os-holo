node_modules/
target/
.DS_Store
*.log
system/tools/*.png
# harness / editor preview artifacts (auto-spawned at the repo root)
_forge_serve.mjs
_serveq.mjs
.claude/

# Holo Voice model weights — content-addressed artifacts, NOT source. Fetched + hash-verified by
# tools/vendor-voice-model.mjs (run it once after clone). κ-pins: voice/models.manifest.json.
system/os/usr/lib/holo/voice/vendor/

# Vendored esbuild-wasm toolchain (content-addressed artifacts — run tools/vendor-esbuild-wasm.mjs)
system/os/usr/lib/holo/holo-forge/vendor/esbuild-wasm/*.wasm
system/os/usr/lib/holo/holo-forge/vendor/esbuild-wasm/browser.min.js

# Vendored Chrome devtools-frontend (ADR-0095) — the built front_end/ is a content-addressed artifact,
# NOT source. Fetched + tarball-integrity-verified by tools/vendor-chrome-devtools.mjs (run once after clone).
system/os/usr/lib/holo/devtools/vendor/

# Vendored interact.js (MIT) — the widget snap engine. Content artifact, fetched + tarball-integrity-verified
# by tools/vendor-interactjs.mjs (run once after clone). Served same-origin, SW-content-verified.
system/os/usr/lib/holo/interactjs/
.holo-tor/

# Neural super-resolution scratch (depth/resrgan ONNX experiments) — research scratch, not part of
# the shell. Purged from history; never commit. Large model blobs are gitignored runtime artifacts.
system/_nsr/

# yt-dlp binary — a fetched tool, not source. Vendor it locally; never commit the binary.
system/tools/bin/yt-dlp.exe

# JupyterLite build state (doit DB) — generated artifact, never commit.
.jupyterlite.doit.db

# local-only private signing key
system/tools/.holo-index-key.json
