      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#app-governed",
        "dcterms:title": "EVERY holospace is GOVERNED at the host by Holo Terms + Holo Privacy — the two core consent functions, enforced where apps mount, not left to each app to opt into. Holo Terms (MyTerms / IEEE 7012-2025) is the capability gate: the host clamps an app to declared ∩ the user's standing term + signed agreement before mounting (holo-launch.mount → the iframe sandbox). Holo Privacy (W3C VC/DPV selective disclosure) is the disclosure gate: the host owns the wallet/keys, an app frame holds nothing, and any disclosure is brokered by the host (holo-gov.js) which stamps the recipient from what it actually mounted (un-forgeable) and gates under the user's stance — default-deny. Both are SURFACED as one shield per focused app (Terms · Privacy), so enforcement is visible, never silent. Universal by construction: proven at the host frames (shell.html · holospace.html), so no app can be an ungoverned island"
      },
      "earl:result": {
        "@type": "earl:TestResult",
        "earl:outcome": {
          "@id": "earl:passed"
        }
