    {
      "@type": "earl:Assertion",
      "earl:assertedBy": {
        "@id": "https://hologram.os/tools/gate"
      },
      "earl:subject": {
        "@id": "https://hologram.os",
        "dcterms:title": "Hologram OS"
      },
      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#holo-dock",
        "dcterms:title": "The dock is native-feel, OS-adaptive and built by ADOPTING desktop-component specs as κ-objects (ADR-0059) — a persistent bottom dock/taskbar that reskins to the host OS (Windows full-width taskbar · macOS centered magnifying dock · iOS/Android safe-area dock · Linux), is golden-ratio-proportioned (holo-phi) and glass-translucent. It runs NO foreign runtime (ADR-0029): it adopts zebar's widget-pack schema (the dock config is a valid zpack instance) and TranslucentTB's accent-state model (opaque/clear/blur/acrylic wired as --holo-glass-* tokens) as byte-pinned content-addressed objects, links to the canonical Holo UI/UX parameters, and every pinned object + the config + the adopted specs are editable like any other substrate object; pin/rearrange/unpin/delete persist to the user's OPFS"
      },
      "earl:result": {
        "@type": "earl:TestResult",
        "earl:outcome": {
          "@id": "earl:passed"
        }
      },
      "earl:mode": {
        "@id": "earl:automatic"
      }
    },
    {
      "@type": "earl:Assertion",
      "earl:assertedBy": {
        "@id": "https://hologram.os/tools/gate"
      },
      "earl:subject": {
        "@id": "https://hologram.os",
        "dcterms:title": "Hologram OS"
      },
      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#app-ui-wired",
        "dcterms:title": "EVERY holospace application is wired to upstream Holo UI (ADR-0030/0057) — the canonical UI parameters (text-size floor · palette · density · accent) are defined and persisted by ONE source, the Holo UI engine loaded by the holospace shell, and propagated to every nested app over the postMessage tree; an app only receives + conforms to them if it loads that engine, so every served app's authored shell must reference the Holo UI engine (holo-theme.js, directly or via the holo-ui-kernel.js / holo-ui.js façades) — no app is an island. Forwarder stubs are checked at their target"
      },
      "earl:result": {
        "@type": "earl:TestResult",
        "earl:outcome": {
          "@id": "earl:passed"
        }
      },
      "earl:mode": {
        "@id": "earl:automatic"
      }
    },
    {
      "@type": "earl:Assertion",
      "earl:assertedBy": {
        "@id": "https://hologram.os/tools/gate"
      },
      "earl:subject": {
        "@id": "https://hologram.os",
        "dcterms:title": "Hologram OS"
      },
      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#app-ui-tokens",
        "dcterms:title": "Holo UI conformance extends from text size to COLOR + SHAPE (ADR-0057) — the canonical palette (--holo-bg/-surface/-ink/-accent/…) and radius (--holo-radius-sm/-/-lg) tokens are the single source, and a hardcoded hex color or px border-radius in an app's authored shell bypasses them. Because color is IDENTITY (apps + the faithful reproductions keep their own colors under the ADOPT-vs-OWN model, ADR-0023), this is a no-regression RATCHET, not a forced rewrite: an app may not add hardcoded themeable values beyond its committed baseline, so the corpus can only get MORE token-conformant. Radius exact-matches (8/12/16px) are adopted as tokens pixel-for-pixel (burndown-app-radius.mjs)"
      },
      "earl:result": {
        "@type": "earl:TestResult",
        "earl:outcome": {
          "@id": "earl:failed"
        }
      },
      "earl:mode": {
        "@id": "earl:automatic"
      }
    },
    {
      "@type": "earl:Assertion",
      "earl:assertedBy": {
        "@id": "https://hologram.os/tools/gate"
      },
      "earl:subject": {
        "@id": "https://hologram.os",
        "dcterms:title": "Hologram OS"
      },
      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#holo-desk",
        "dcterms:title": "Holo Desk is the substrate-native DESKTOP (ADR-0061) — the full native folder/icon experience in any browser, made magical by leaning into the UOR content-addressed substrate. CREATE: right-click 'New ▸ Folder/Text/App shortcut' (+ inline-rename; Home is read/WRITE). PIN ANYTHING: drop or paste any app, file, URL, or κ/did:holo onto the desktop and it becomes a self-verifying icon (files import + content-address on write; identifiers become object pins; apps become launchers). ORGANISE: drag to arrange, NEST onto a folder, marquee multi-select, copy/cut/paste, keyboard nav + type-ahead, and delete → Trash with Undo (⌘Z). PROVE: every icon carries its did:holo κ (a verify badge re-derives on hover, Law L5), 'Copy holo:// link' shares an object by content address, 'Copy desktop κ' turns the WHOLE arrangement into one shareable address, and Quick Look (Space) shows the live κ. FEEL: reskins to the host OS (Windows/macOS) via HoloPlatform, insets around the dock, animates with taste (reduced-motion aware); folders show covers that match their contents. Reuses the OS engines, no foreign runtime (ADR-0029); proven by driving the real desktop in Chromium (23 checks)."
      },
      "earl:result": {
        "@type": "earl:TestResult",
        "earl:outcome": {
          "@id": "earl:passed"
        }
      },
      "earl:mode": {
        "@id": "earl:automatic"
      }
    },
    {
      "@type": "earl:Assertion",
      "earl:assertedBy": {
        "@id": "https://hologram.os/tools/gate"
      },
      "earl:subject": {
        "@id": "https://hologram.os",
        "dcterms:title": "Hologram OS"
      },
      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#holo-ux",
        "dcterms:title": "Holo UX is the single canonical, self-verifying source of the EXPERIENCE (ADR-0062) — the experience analogue of Holo UI's token contract. The system autodetects the host OS (Windows · macOS · iOS · iPadOS · Android · ChromeOS · Linux) and adapts its native feel dynamically — modifier key, window-control side, font, accent, shortcuts (holo-platform.js → data-holo-platform, seeded without overriding the user) — so it feels familiar and effortless on every machine. Thirteen tenets (the five founding principles + Steve Jobs's eight UX lessons) are each a checkable obligation; capability tier, plain voice and a tier-aware resource budget (time · attention · compute · memory · energy held sacred, interaction ≤100ms / RAIL) are resolved, not guessed. The canonical parameters are sealed as ONE UOR object (etc/holo-ux/doctrine.uor.json) that re-derives to its content address and whose source links re-derive (Law L5) — every holospace binds the κ rather than re-implementing UX"
      },
      "earl:result": {
        "@type": "earl:TestResult",
        "earl:outcome": {
          "@id": "earl:passed"
        }
      },
      "earl:mode": {
        "@id": "earl:automatic"
      }
    },
    {
      "@type": "earl:Assertion",
      "earl:assertedBy": {
        "@id": "https://hologram.os/tools/gate"
      },
      "earl:subject": {
        "@id": "https://hologram.os",
        "dcterms:title": "Hologram OS"
      },
      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#app-ux-conformance",
        "dcterms:title": "The Holo UX doctrine (ADR-0062) is strictly adhered to by EVERY holospace application, not just the OS chrome — so every app is beautiful, functional and coherent with the whole OS. Loading the ONE engine every app already loads (holo-theme.js) bootstraps the Holo UX runtime (holo-ux.js), so every app inherits the WHOLE doctrine — the host-OS native feel, the capability tier, the resource budget, the live propagation — by binding one canonical wire (Law L2), with no per-app script tag. This witness proves that inheritance is real for every served app (the carrier is intact + the canonical doctrine object re-derives + every app loads the engine), and holds each app to its OWN-shell obligations: its manifest keeps the plain voice (jargon-free — signal over noise); it honors prefers-reduced-motion through the ONE OS-wide guard every app inherits from holo-theme.css (time/compute/energy held sacred — WCAG 2.3.3, no per-app copy needed, no app may override it with its own !important motion); and its modifier keys are NATIVE-ADAPTIVE — no unconditional Apple-only glyph (⌘/⌥), the host's modifier is derived (HoloPlatform/metaKey) or rendered by the inherited data-holo-shortcut helper (⌘N on macOS · Ctrl+N on Windows/Linux). Read-only over the served app repo — no edits, no re-lock"
      },
      "earl:result": {
        "@type": "earl:TestResult",
        "earl:outcome": {
          "@id": "earl:passed"
        }
      },
      "earl:mode": {
        "@id": "earl:automatic"
      }
    },
    {
      "@type": "earl:Assertion",
      "earl:assertedBy": {
        "@id": "https://hologram.os/tools/gate"
      },
      "earl:subject": {
        "@id": "https://hologram.os",
        "dcterms:title": "Hologram OS"
      },
      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#share-to-run",
        "dcterms:title": "Share-to-Run — the growth loop (ADR-064): a SHARED holospace link (one carrying #k= provenance) lands a GUEST fullscreen in the running app, with an OS-level chrome laid OVER the app's sandboxed frame (so the substrate speaks, not the app) — run it, REMIX it (one tap to your own editable copy in the World shell), SHARE it (the content-addressed link, no sign-in), SAVE it (the pull to create your self-sovereign Space, never a gate before value). The chrome shows the app's VERIFIED content address (κ, re-derived not URL-trusted), is contextual to shared landings only (a bare kiosk link stays clean), rides the canonical --holo-* tokens + the readability floor, and honors prefers-reduced-motion. The native, private-first viral loop (share-to-run-to-remix) over the content-addressed substrate — no central feed, no parallel infrastructure (Law L1/L4). The loop SELF-seeds from EVERY creation surface: both the World shell's Share (its modal · QR · Copy all carry it) AND the in-app Manage panel emit this magic link, so a creator's first share lands the recipient in the chrome (the frame resolves the link by content address OR by the app's served-path id). Proven by driving the whole loop in real Chromium (13 checks — shared landing renders, kiosk stays clean, the World shell Share AND the Manage panel each emit the magic link, a path-built link resolves and lands in the chrome, and that link lands the next guest back in the chrome: the loop closed end-to-end)"
      },
      "earl:result": {
        "@type": "earl:TestResult",
        "earl:outcome": {
          "@id": "earl:passed"
        }
      },
      "earl:mode": {
        "@id": "earl:automatic"
      }
    },
    {
      "@type": "earl:Assertion",
      "earl:assertedBy": {
        "@id": "https://hologram.os/tools/gate"
      },
      "earl:subject": {
        "@id": "https://hologram.os",
        "dcterms:title": "Hologram OS"
      },
      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#holo-product",
        "dcterms:title": "Holo Product is the canonical upstream foundation for building beautiful, valuable and delightful Hologram-native products (ADR-0065) — it BUNDLES and BALANCES the two already-wired faculties of the UX·&·UI diagram into one self-verifying object: five UX faculties (interaction design · wireframes · information architecture · user research · scenarios — the experience, Holo UX) and five UI faculties (visual design · colours · graphic design · layouts · typography — the look, Holo UI), each mapped to where it is already wired in the OS and each a checkable obligation, with neither hemisphere allowed to ship without the other. It also binds a HYBRID delivery method (discover · define · design · build · verify · deliver/iterate) drawn from the field's project-management frameworks (Agile · Scrum · Kanban · Waterfall · Lean · PRINCE2 · Six Sigma) — the predictive-governance-plus-agile-execution the substrate already lives (an ADR is the decision record, a witness is the definition of done, the fail-closed gate is the stage-gate, the resource budget is the Lean waste discipline, a sealed κ is the predictable artifact). The bundle is sealed as ONE UOR object (etc/holo-product/product.uor.json) that re-derives to its content address and Merkle-links BOTH hemispheres — the sealed Holo UX doctrine and the canonical Holo UI token/engine layer — so a product binds the κ rather than re-deciding the basics (Law L5); it rests on the proven Holo UI + Holo UX gate rows"
      },
      "earl:result": {
        "@type": "earl:TestResult",
        "earl:outcome": {
          "@id": "earl:passed"
        }
      },
      "earl:mode": {
        "@id": "earl:automatic"
      }
    }
  ]
