        "@id": "https://hologram.os/tools/gate"
      },
      "earl:subject": {
        "@id": "https://hologram.os",
        "dcterms:title": "Hologram OS"
      },
      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#own-demo",
        "dcterms:title": "End-to-end Own, witnessed (ADR-053): an AI AGENT BUYS A HOLOSPACE FROM A HUMAN on the content-addressable substrate — self-sovereign human + agent identities; the agent does trustless due diligence over MCP (own_verify); the human signs the hand-over; payment settles ONLY against the proven title (pay-for-proven — a forged sale releases nothing); the agent becomes the verified owner — every step re-derives (Law L5), no server. Composes identity ⊕ own ⊕ settle ⊕ MCP"
      },
