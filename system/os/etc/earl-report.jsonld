      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#chain",
        "dcterms:title": "OMNICHAIN, native in every holospace (ADR-053): the Chain Abstraction Layer unifies the fragmented blockchain ecosystem UNDER the κ substrate — NOT a bridge between chains, but each chain a verifiable projection of + anchor for the one κ universe. CAIP (CAIP-2/10/19) names any chain/account/asset; resolve() turns any chain identifier into a SELF-VERIFYING κ object in the one graph (two different chains' accounts land as distinct, re-derivable κ objects); did:pkh makes a chain wallet a holospace principal that holds an Own Title with no new key; anchor/pay route an INTENT to the right chain by namespace via the one default-deny wallet seam — the holospace speaks κ + intents, never a chain"
      },
      "earl:result": {
        "@type": "earl:TestResult",
        "earl:outcome": {
          "@id": "earl:passed"
        }
      },
      "earl:mode": {
