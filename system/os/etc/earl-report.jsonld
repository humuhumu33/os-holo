      }
    },
    {
      "@type": "earl:Assertion",
      "earl:assertedBy": {
        "@id": "https://hologram.os/tools/gate"
      },
      "earl:subject": {
        "@id": "https://hologram.os",
        "dcterms:title": "Hologram OS"
      },
      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#holo-ui-conformance",
        "dcterms:title": "Holo UI is the single canonical UI source with a strict readability FLOOR (ADR-0057) — one engine (holo-theme.js) drives the --holo-* design tokens for every holospace, and --holo-font-min is a minimum text size below which no token-rendered text can fall: holo-theme.css floors the root font-size and holo-mobile.css floors the sub-1rem type ramp + form controls with max(var(--holo-font-min), …), and NO first-party UI hardcodes a sub-floor px font-size that would silently bypass it (verbatim SDDM greeter / Plymouth splash reproductions exempt). Strict conformance to the one set of canonical parameters makes the whole experience coherent"
      },
      "earl:result": {
        "@type": "earl:TestResult",
        "earl:outcome": {
          "@id": "earl:passed"
        }
      },
      "earl:mode": {
        "@id": "earl:automatic"
      }
    },
    {
      "@type": "earl:Assertion",
      "earl:assertedBy": {
        "@id": "https://hologram.os/tools/gate"
      },
      "earl:subject": {
        "@id": "https://hologram.os",
        "dcterms:title": "Hologram OS"
      },
      "earl:test": {
        "@id": "https://hologram.os/conformance/os2#app-ui-conformance",
        "dcterms:title": "The Holo UI readability floor (ADR-0057) is ENFORCED across EVERY holospace application, not just the OS chrome — a ratchet over the served app repo holds every app's authored shell to no NEW sub-16px font-size beyond its committed baseline (the 'betterer' no-new-violations pattern): no native application can introduce text too small to read, the baseline is the visible burn-down, and burning it down only ever passes. Apps already inherit the floor for token/rem text via the --holo-* tokens + postMessage propagation; this closes the bypass where an app hardcodes px in its own shell"
      },
      "earl:result": {
        "@type": "earl:TestResult",
