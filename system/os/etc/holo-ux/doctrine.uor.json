  "schema:name": "Holo UX doctrine — the canonical upstream UX parameters of Hologram OS",
  "schema:description": "Why: an experience should feel native, familiar and effortless on every machine, and treat the user's time, attention and energy as sacred. How: one self-verifying object declares the canonical UX parameters — the host OS is autodetected and the experience adapts to its native feel; thirteen tenets (the founding five + Steve Jobs's eight UX lessons) are each a checkable obligation; capability, voice and budget are resolved, not guessed. What: every holospace binds this object's κ rather than re-implementing UX, the same way Holo UI's tokens are bound — re-derive this did and each linked source κ to verify (Law L5).",
  "schema:softwareVersion": "1.0",
  "dcterms:conformsTo": "https://hologram.os/ns/ux",
  "dcterms:license": "https://creativecommons.org/publicdomain/zero/1.0/",
  "hosux:tenets": [
    {
      "@id": "hosux:native-adaptive",
      "group": "founding",
      "prefLabel": "Native by autodetection",
      "hosux:obligation": "Resolve the host platform from the one resolver (holo-platform.js) and bind its native profile — modifier key, window-control side, font, accent, shortcuts (data-holo-platform) — dynamically; never hardcode one OS's idiom."
    },
    {
      "@id": "hosux:familiar-effortless",
      "group": "founding",
      "prefLabel": "Familiar and effortless",
      "hosux:obligation": "Reuse the host OS's established patterns and the canonical Holo UI tokens (--holo-*); introduce no bespoke interaction where a native one already exists."
    },
    {
      "@id": "hosux:moments-of-magic",
      "group": "founding",
      "prefLabel": "Magic on curiosity's terms",
      "hosux:obligation": "Surface advanced capability through progressive disclosure; every surface is self-descriptive (a clear label/affordance, not a tutorial); no forced interruption of the user's flow."
    },
    {
      "@id": "hosux:sacred-resources",
      "group": "founding",
      "prefLabel": "Treat time, attention, money, compute and energy as sacred",
      "hosux:obligation": "Hold the declared tier-aware resource budget (cold-start, interaction ≤100ms, bytes-per-surface, memory, maxDpr — holo-perf-budget.json); add no work the task does not require."
    },
    {
      "@id": "hosux:signal-over-noise",
      "group": "founding",
      "prefLabel": "Maximize signal, minimize noise",
      "hosux:obligation": "Route colour through the canonical palette (no attention-grabbing hardcodes — ADR-0057), respect the readability floor, and keep the plain voice (concise, jargon-free, why→how→what — holo-voice.mjs)."
    },
    {
      "@id": "hosux:design-is-how-it-works",
      "group": "jobs",
      "prefLabel": "Design is how it works",
      "hosux:obligation": "Conformance is behavioural, not skin-deep: a holospace binds the experience parameters (this doctrine), and its content address commits function and form together."
    },
    {
      "@id": "hosux:simplicity-is-the-work",
      "group": "jobs",
      "prefLabel": "Simplicity, ruthlessly refined",
      "hosux:obligation": "Prefer the fewest controls and an obvious default; an action a first-time user cannot guess is a fault, not a feature."
    },
    {
      "@id": "hosux:user-first",
      "group": "jobs",
      "prefLabel": "The user first, end to end",
      "hosux:obligation": "The experience is one continuous flow (boot → shell → app); no app is an island — every surface binds the one canonical doctrine."
    },
    {
      "@id": "hosux:focus-say-no",
      "group": "jobs",
      "prefLabel": "Focus — say no to protect great",
      "hosux:obligation": "Each surface does one thing well; secondary actions are disclosed on demand, not displayed by default."
    },
    {
      "@id": "hosux:attention-to-detail",
      "group": "jobs",
      "prefLabel": "Detail in the unseen, too",
      "hosux:obligation": "The parameters reach a surface's chrome honestly and say where they cannot (pixel-only guests: VM/canvas/video); nothing is left half-finished behind the visible edge."
    },
    {
      "@id": "hosux:think-different",
      "group": "jobs",
      "prefLabel": "Redefine the question",
      "hosux:obligation": "The experience is a re-derivable κ-object (Law L5), not a config file trusted by its location; verify by re-derivation, refuse a tampered byte."
    },
    {
      "@id": "hosux:seamless-integration",
      "group": "jobs",
      "prefLabel": "Seamless, integrated experience",
      "hosux:obligation": "One source (this doctrine) propagates to every surface over the postMessage tree; changing it re-flows the whole system live, with no rebuild and no restart."
    },
    {
      "@id": "hosux:emotional-delight",
      "group": "jobs",
      "prefLabel": "It just works — and delights",
      "hosux:obligation": "Defaults are beautiful and correct out of the box (bind the κ, do not re-implement); reduced-motion and accessibility are honoured so delight never costs comfort."
    }
  ],
