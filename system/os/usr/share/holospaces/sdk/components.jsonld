      "schema:text": "{\"bg\":\"#0b0f17\",\"mobjects\":{\"ring\":{\"type\":\"circle\",\"radius\":2,\"stroke\":\"#30363d\",\"width\":3},\"d\":{\"type\":\"dot\",\"radius\":0.14,\"fill\":\"#f0883e\",\"stroke\":\"#f0883e\",\"pos\":[2,0]}},\"timeline\":[{\"play\":\"Create\",\"target\":\"ring\",\"run\":1},{\"play\":\"Trace\",\"target\":\"d\",\"path\":{\"type\":\"circle\",\"radius\":2},\"run\":2.2},{\"wait\":0.4}],\"manim_src\":\"from manim import *\\n\\nclass MovingDot(Scene):\\n    def construct(self):\\n        ring = Circle(radius=2)\\n        dot = Dot(ring.point_from_proportion(0))\\n        self.play(Create(ring))\\n        self.play(MoveAlongPath(dot, ring), run_time=2)\\n        self.wait()\"}"
