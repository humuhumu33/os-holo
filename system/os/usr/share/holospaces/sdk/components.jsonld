  "@id": "https://hologram.os/apps/world/components",
  "@type": "dcat:Catalog",
  "dcterms:title": "Hologram OS — content-addressed component library",
  "dcterms:description": "A library of reusable UI components, each a self-verifying UOR object (did:holo). Browse + preview in the World shell and import in one click — the import re-derives the same κ (Law L5). The seed of an internet-wide, content-addressed object library.",
  "dcat:dataset": [
    {
      "@id": "did:holo:sha256:3e2c487c580fc441d1168c235853e580cbadf66bf0d9bd1e61ad7249ab7fb789",
      "@type": [
        "schema:SoftwareSourceCode",
        "schema:WebApplication",
        "prov:Entity"
      ],
      "schema:name": "Button",
      "schema:description": "A solid accent button that counts its taps. The OS accent flows in automatically.",
      "schema:applicationCategory": "Controls",
      "schema:license": "MIT",
      "schema:keywords": [],
      "hosc:accent": "#1f6feb",
      "hosc:library": "Hologram",
      "hosc:kind": "native",
      "schema:programmingLanguage": "HTML",
      "dcterms:identifier": "button",
      "prov:wasGeneratedBy": {
        "@id": "https://hologram.os/tools/build-components"
      },
      "schema:text": "<div class=\"wrap\"><button data-on:click=\"taps++\" data-text=\"label\"></button><div class=\"n\">tapped <b data-text=\"taps\"></b></div></div>\n<script type=\"module\">export default { label: \"Click me\", taps: 0 }</script>\n<style>.wrap{height:100%;display:grid;place-content:center;gap:14px;text-align:center;color:#c9d1d9}\nbutton{background:var(--accent,#1f6feb);color:#fff;border:0;border-radius:12px;padding:14px 28px;font:600 16px system-ui;cursor:pointer;box-shadow:0 6px 18px #0006}\nbutton:active{transform:translateY(1px)}.n{color:#8b949e;font:13px system-ui}</style>"
    },
    {
      "@id": "did:holo:sha256:b442abff6e54eb72401cbce89dc3a5b4d718037bae46cf25e4a46412fc56b5c0",
      "@type": [
        "schema:SoftwareSourceCode",
        "schema:WebApplication",
        "prov:Entity"
      ],
      "schema:name": "Switch",
      "schema:description": "An iOS-style toggle. Click to flip; the track animates to the accent when on.",
      "schema:applicationCategory": "Controls",
      "schema:license": "MIT",
      "schema:keywords": [],
      "hosc:accent": "#3fb950",
      "hosc:library": "Hologram",
      "hosc:kind": "native",
      "schema:programmingLanguage": "HTML",
      "dcterms:identifier": "toggle",
      "prov:wasGeneratedBy": {
        "@id": "https://hologram.os/tools/build-components"
      },
      "schema:text": "<div class=\"wrap\"><div class=\"sw\" data-attr:data-on=\"on\" data-on:click=\"on=!on\"><span class=\"knob\"></span></div><div class=\"s\" data-text=\"on ? 'On' : 'Off'\"></div></div>\n<script type=\"module\">export default { on: false }</script>\n<style>.wrap{height:100%;display:grid;place-content:center;gap:14px;text-align:center;color:#c9d1d9}\n.sw{width:64px;height:36px;border-radius:999px;background:#30363d;cursor:pointer;position:relative;transition:background .18s}\n.sw[data-on=\"true\"]{background:var(--accent,#3fb950)}.knob{position:absolute;top:3px;left:3px;width:30px;height:30px;border-radius:50%;background:#fff;transition:transform .18s}\n.sw[data-on=\"true\"] .knob{transform:translateX(28px)}.s{font:13px system-ui;color:#8b949e}</style>"
    },
    {
      "@id": "did:holo:sha256:0bcab2bbe5f980964f2dff95867fc95da2997a20a0903e7d6ffac93353f17355",
      "@type": [
        "schema:SoftwareSourceCode",
        "schema:WebApplication",
        "prov:Entity"
      ],
      "schema:name": "Sticky Note",
      "schema:description": "An editable yellow note. Type into it — the text is the component's live state.",
      "schema:applicationCategory": "Productivity",
      "schema:license": "MIT",
      "schema:keywords": [],
      "hosc:accent": "#febc2e",
      "hosc:library": "Hologram",
      "hosc:kind": "native",
      "schema:programmingLanguage": "HTML",
      "dcterms:identifier": "sticky",
      "prov:wasGeneratedBy": {
        "@id": "https://hologram.os/tools/build-components"
      },
      "schema:text": "<textarea class=\"note\" data-model=\"text\" placeholder=\"Type a note…\"></textarea>\n<script type=\"module\">export default { text: \"\" }</script>\n<style>.note{display:block;height:100%;width:100%;border:0;background:linear-gradient(160deg,#fde68a,#fbbf24);color:#1a1a1a;font:15px/1.6 system-ui;padding:18px;resize:none;outline:none}</style>"
    },
    {
      "@id": "did:holo:sha256:98dc8fbddc1d7e7d4e4a26a82aa33d817e06e037cb1a95b4244656d168ea613c",
      "@type": [
        "schema:SoftwareSourceCode",
        "schema:WebApplication",
        "prov:Entity"
      ],
      "schema:name": "Clock",
      "schema:description": "A live digital clock — ticks every second, cleans up its timer when closed.",
      "schema:applicationCategory": "Widgets",
      "schema:license": "MIT",
      "schema:keywords": [],
      "hosc:accent": "#2dd4bf",
      "hosc:library": "Hologram",
      "hosc:kind": "native",
      "schema:programmingLanguage": "HTML",
      "dcterms:identifier": "clock",
      "prov:wasGeneratedBy": {
        "@id": "https://hologram.os/tools/build-components"
      },
      "schema:text": "<div class=\"clock\"><div class=\"t\" data-text=\"now\"></div><div class=\"d\" data-text=\"date\"></div></div>\n<script type=\"module\">export default { now: \"\", date: \"\",\n  init(){ const tick=()=>{ const d=new Date(); this.now=d.toLocaleTimeString(); this.date=d.toLocaleDateString(undefined,{weekday:'long',month:'long',day:'numeric'}); }; tick(); this._i=setInterval(tick,1000); },\n  destroy(){ clearInterval(this._i); } }</script>\n<style>.clock{height:100%;display:grid;place-content:center;text-align:center;gap:8px;color:#c9d1d9}\n.t{font:600 46px ui-monospace,monospace;letter-spacing:1px}.d{color:#8b949e;font:14px system-ui}</style>"
    },
    {
      "@id": "did:holo:sha256:3973ab405302febcb2e80491fe53332bad7bd847ee2411221127425f31cef041",
      "@type": [
        "schema:SoftwareSourceCode",
        "schema:WebApplication",
        "prov:Entity"
      ],
      "schema:name": "Stepper",
      "schema:description": "A plus/minus stepper around a big live number. Reactive state, no framework.",
      "schema:applicationCategory": "Controls",
      "schema:license": "MIT",
      "schema:keywords": [],
      "hosc:accent": "#a371f7",
      "hosc:library": "Hologram",
      "hosc:kind": "native",
      "schema:programmingLanguage": "HTML",
      "dcterms:identifier": "counter",
      "prov:wasGeneratedBy": {
        "@id": "https://hologram.os/tools/build-components"
      },
      "schema:text": "<div class=\"wrap\"><button data-on:click=\"n--\">−</button><div class=\"n\" data-text=\"n\"></div><button data-on:click=\"n++\">+</button></div>\n<script type=\"module\">export default { n: 0 }</script>\n<style>.wrap{height:100%;display:flex;align-items:center;justify-content:center;gap:20px;color:#c9d1d9}\nbutton{width:50px;height:50px;border-radius:50%;border:1px solid #30363d;background:#161b22;color:#fff;font-size:24px;cursor:pointer}\nbutton:hover{border-color:var(--accent,#a371f7)}.n{font:600 42px ui-monospace,monospace;min-width:90px;text-align:center}</style>"
    },
    {
      "@id": "did:holo:sha256:b9af3c3b7003863c3f8e45d907d5f707adf7baa8e4e7fa45806d3ac80f386651",
      "@type": [
        "schema:SoftwareSourceCode",
        "schema:WebApplication",
        "prov:Entity"
      ],
      "schema:name": "Color Picker",
      "schema:description": "A swatch palette; pick one and the big preview + hex update. Lists render with data-for.",
      "schema:applicationCategory": "Widgets",
      "schema:license": "MIT",
      "schema:keywords": [],
      "hosc:accent": "#ff66cc",
      "hosc:library": "Hologram",
      "hosc:kind": "native",
      "schema:programmingLanguage": "HTML",
      "dcterms:identifier": "color",
      "prov:wasGeneratedBy": {
        "@id": "https://hologram.os/tools/build-components"
      },
      "schema:text": "<div class=\"wrap\"><div class=\"big\" data-attr:style=\"'background:'+c\"></div><div class=\"row\"><template data-for=\"x in palette\"><button data-on:click=\"c=x\" data-attr:style=\"'background:'+x\"></button></template></div><div class=\"hex\" data-text=\"c\"></div></div>\n<script type=\"module\">export default { c: \"#1f6feb\", palette: [\"#1f6feb\",\"#3fb950\",\"#f85149\",\"#febc2e\",\"#a371f7\",\"#2dd4bf\",\"#ff66cc\",\"#e6edf3\"] }</script>\n<style>.wrap{height:100%;display:grid;place-content:center;gap:14px;text-align:center;color:#c9d1d9}\n.big{width:160px;height:80px;border-radius:12px;margin:0 auto;border:1px solid #ffffff22}\n.row{display:flex;gap:8px;justify-content:center}.row button{width:26px;height:26px;border-radius:7px;border:1px solid #ffffff22;cursor:pointer}\n.hex{font:600 16px ui-monospace,monospace}</style>"
    },
    {
      "@id": "did:holo:sha256:c387e98556a760f1944469ccdc9fe5e3af291657b530e96f46f5921615b50a9c",
      "@type": [
        "schema:SoftwareSourceCode",
        "schema:WebApplication",
        "prov:Entity"
      ],
      "schema:name": "Calculator",
      "schema:description": "A fully working calculator — a complete little app, content-addressed like any object.",
      "schema:applicationCategory": "Apps",
      "schema:license": "MIT",
      "schema:keywords": [],
      "hosc:accent": "#0a84ff",
      "hosc:library": "Hologram",
      "hosc:kind": "native",
      "schema:programmingLanguage": "HTML",
      "dcterms:identifier": "calculator",
      "prov:wasGeneratedBy": {
        "@id": "https://hologram.os/tools/build-components"
      },
      "schema:text": "<div class=\"calc\"><div class=\"disp\" data-text=\"display\"></div><div class=\"keys\"><template data-for=\"k in keys\"><button data-on:click=\"press(k)\" data-text=\"k\" data-attr:class=\"'op'.includes(k)?'':''\"></button></template></div></div>\n<script type=\"module\">export default {\n  display: \"0\", _a: null, _op: null, _fresh: true,\n  keys: [\"C\",\"÷\",\"×\",\"−\",\"7\",\"8\",\"9\",\"+\",\"4\",\"5\",\"6\",\"=\",\"1\",\"2\",\"3\",\"0\",\".\"],\n  press(k){\n    if(k===\"C\"){ this.display=\"0\"; this._a=null; this._op=null; this._fresh=true; return; }\n    if(\"+−×÷\".includes(k)){ this._a=parseFloat(this.display); this._op=k; this._fresh=true; return; }\n    if(k===\"=\"){ if(this._op!=null){ const a=this._a,b=parseFloat(this.display); let r=b; if(this._op===\"+\")r=a+b; if(this._op===\"−\")r=a-b; if(this._op===\"×\")r=a*b; if(this._op===\"÷\")r=b?a/b:0; this.display=String(+r.toFixed(8)); this._op=null; this._fresh=true; } return; }\n    if(this._fresh){ this.display=(k===\".\")?\"0.\":k; this._fresh=false; }\n    else { if(k===\".\"&&this.display.includes(\".\"))return; this.display=(this.display===\"0\"&&k!==\".\")?k:this.display+k; }\n  }\n}</script>\n<style>.calc{height:100%;display:flex;flex-direction:column;background:#0d1117;color:#c9d1d9}\n.disp{padding:18px;text-align:right;font:600 34px ui-monospace,monospace;overflow:hidden}\n.keys{flex:1;display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#21262d}\n.keys button{border:0;background:#161b22;color:#e6edf3;font:18px ui-monospace,monospace;cursor:pointer}\n.keys button:hover{background:#21262d}.keys button:active{background:var(--accent,#0a84ff)}</style>"
    },
