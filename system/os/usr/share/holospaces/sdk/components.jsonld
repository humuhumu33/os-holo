      "prov:wasGeneratedBy": {
        "@id": "https://hologram.os/tools/build-components"
      },
      "schema:text": "{\"bg\":\"#0b0f17\",\"mobjects\":{\"ax\":{\"type\":\"line\",\"from\":[-6,0],\"to\":[6,0],\"stroke\":\"#30363d\",\"width\":3},\"ay\":{\"type\":\"line\",\"from\":[0,-3],\"to\":[0,3],\"stroke\":\"#30363d\",\"width\":3},\"sine\":{\"type\":\"plot\",\"fn\":\"sin\",\"x0\":-6,\"x1\":6,\"yscale\":1.7,\"stroke\":\"#2dd4bf\",\"width\":5}},\"timeline\":[{\"play\":\"Create\",\"target\":\"ax\",\"run\":0.4},{\"play\":\"Create\",\"target\":\"ay\",\"run\":0.4},{\"play\":\"Create\",\"target\":\"sine\",\"run\":1.8},{\"wait\":0.7}],\"manim_src\":\"from manim import *\\n\\nclass SineWave(Scene):\\n    def construct(self):\\n        ax = Axes()\\n        graph = ax.plot(lambda x: np.sin(x), color=TEAL)\\n        self.add(ax); self.play(Create(graph))\\n        self.wait()\"}"
    },
