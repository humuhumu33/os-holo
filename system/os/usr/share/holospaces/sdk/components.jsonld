      "dcterms:identifier": "manim-write",
      "prov:wasGeneratedBy": {
        "@id": "https://hologram.os/tools/build-components"
      },
      "schema:text": "{\"bg\":\"#0b0f17\",\"mobjects\":{\"t\":{\"type\":\"text\",\"text\":\"Hologram\",\"size\":1.2,\"color\":\"#e6edf3\",\"opacity\":0}},\"timeline\":[{\"play\":\"Write\",\"target\":\"t\",\"run\":1},{\"wait\":0.4},{\"play\":\"Transform\",\"target\":\"t\",\"to\":{\"text\":\"× Manim\",\"color\":\"#2dd4bf\"},\"run\":1},{\"wait\":0.7}],\"manim_src\":\"from manim import *\\n\\nclass WriteText(Scene):\\n    def construct(self):\\n        t = Text('Hologram')\\n        self.play(Write(t))\\n        self.play(Transform(t, Text('x Manim')))\\n        self.wait()\"}"
    },
